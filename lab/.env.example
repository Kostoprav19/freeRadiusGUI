# Copy to `lab/.env` and edit as needed. `docker compose` reads .env
# automatically when invoked from `lab/`. All values here already match the
# `${VAR:-default}` fallbacks in `compose.yaml`, so the stack also works with
# no `.env` at all — this file is purely for overriding defaults.

# ---------- MySQL ----------
MYSQL_ROOT_PASSWORD=rootpw
MYSQL_DATABASE=freeradiusgui
MYSQL_USER=freeradius
MYSQL_PASSWORD=koJasmoJas2
# Host port the MySQL container binds to. Change if 3306 is already in use.
MYSQL_PORT=3306

# ---------- App (only used with `--profile app`) ----------
APP_PORT=8080

# ---------- FreeRADIUS dev server (only used with `--profile app`) ----------
# Host UDP ports the freeradius container binds to.
RADIUS_AUTH_PORT=1812
RADIUS_ACCT_PORT=1813
# Seconds between radclient bursts.
RADCLIENT_INTERVAL=5
